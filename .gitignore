# Dependencies
node_modules/

# Build / compiled output (Node, Express, Nest, Vite, Next production)
dist/
dist-ssr/
build/
out/
.next/
.nuxt/
.output/
.tmp/
tmp/
out-tsc/

# Vite (vanilla & React; https://vite.dev/guide/#index-html-and-project-root)
.vite/
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# Next.js (https://github.com/vercel/next.js/tree/canary/packages/create-next-app)
.vercel/
next-env.d.ts

# Yarn Berry (https://yarnpkg.com/getting-started/qa#which-files-should-be-gitignored)
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Testing & coverage
coverage/
*.lcov
.nyc_output/

# Caches (tooling)
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
.npm/
.pnpm-store/

# Optional archives from `npm pack`
*.tgz

# Environment (commit examples only; aligns with github/gitignore Node)
.env
.env.*
!.env.example

# Local-only overrides (Vite; *.local certs, etc.)
*.local

# Certificates / local HTTPS (common with Next.js dev proxies)
*.pem

# TypeScript
*.tsbuildinfo

# OS
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# IDEs and editors
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
*.code-workspace
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# VS Code — ignore editor state; allow shared workspace config
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# VS Code extension testing
.vscode-test/
